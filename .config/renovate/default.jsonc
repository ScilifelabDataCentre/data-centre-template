{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration",
    "abandonments:recommended",
    "security:minimumReleaseAgeNpm",
    ":maintainLockFilesWeekly",
    ":automergeDisabled",
    ":gitSignOff",
    ":ignoreUnstable",
    ":prConcurrentLimit10",
    ":prHourlyLimit1",
    ":renovatePrefix"
  ],
  "labels": ["dependencies"]
}